---
import { safeCollection } from '../lib/collections';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import OrganizerCard from '../components/OrganizerCard.astro';
import { HOME, SITE, STRINGS } from '../config';

const now = new Date();
const events = (await safeCollection('events')).filter((e) => !e.data.draft);
const upcoming = events.filter((e) => e.data.date >= now).sort((a, b) => +a.data.date - +b.data.date);
const next = upcoming[0];

const posts = (await safeCollection('blog')).filter((p) => !p.data.draft).sort((a, b) => +b.data.date - +a.data.date).slice(0, 3);
/* value = "@pastEventCount" renders the live number of past events,
   rounded down to a "70+" style once there are ten or more (Hugo parity). */
const pastCount = events.filter((e) => e.data.date < now).length;
const statValue = (v: string) =>
  v === '@pastEventCount' ? (pastCount >= 10 ? `${Math.floor(pastCount / 10) * 10}+` : String(pastCount)) : v;
const nextVenue = next?.data.venueRef ? (await safeCollection('venues')).find((v) => v.id === next.data.venueRef)?.data.title : undefined;
const organizers = (await safeCollection('organizers')).sort((a, b) => a.data.weight - b.data.weight);

const h = HOME;
---

<BaseLayout>
  {h.hero && (
    <section class="g-hero">
      <div class="g-container g-hero__grid">
        <div class="g-hero__content">
          {h.hero.eyebrow && <span class="g-eyebrow">{h.hero.eyebrow}</span>}
          <h1>{h.hero.title}</h1>
          {h.hero.lead && <p class="g-hero__lead">{h.hero.lead}</p>}
          {h.hero.ctas && (
            <div class="g-row">
              {h.hero.ctas.map((c) => (
                <a class={`g-btn g-btn--lg g-btn--${c.variant ?? 'primary'}`} href={c.url}>
                  {'icon' in c && c.icon && <i class={c.icon} aria-hidden="true"></i>}{c.label}
                </a>
              ))}
            </div>
          )}
        </div>
        {h.hero.image && (
          <div class="g-hero__media"><img src={h.hero.image} alt={SITE.title} /></div>
        )}
      </div>
    </section>
  )}

  {h.stats && (
    <section class="g-bg-ink">
      <div class="g-container g-stats">
        {h.stats.map((s) => (
          <div class="g-stat"><div class="g-stat__n">{statValue(s.value)}</div><div class="g-stat__l">{s.label}</div></div>
        ))}
      </div>
    </section>
  )}

  {h.features && (
    <section class="g-bg-white g-section">
      <div class="g-container">
        {h.featuresHead && (
          <div class="g-section-head">
            {h.featuresHead.eyebrow && <span class="g-eyebrow">{h.featuresHead.eyebrow}</span>}
            <h2>{h.featuresHead.title}</h2>
            {h.featuresHead.lead && <p class="g-lead">{h.featuresHead.lead}</p>}
          </div>
        )}
        <div class="g-grid-3" style="margin-top:var(--space-5)">
          {h.features.map((f) => (
            <div class="g-card"><div class="g-card__body">
              <span class="g-medallion"><i class={f.icon} aria-hidden="true"></i></span>
              <h3 class="g-card__title">{f.title}</h3>
              <p class="g-card__text">{f.body}</p>
            </div></div>
          ))}
        </div>
      </div>
    </section>
  )}

  {next && (
    <section class="g-bg-wash-soft">
      <div class="g-container g-feature">
        {(next.data.image ?? h.hero.image) && <div class="g-feature__media"><img src={next.data.image ?? h.hero.image} alt={next.data.title} /></div>}
        <div class="g-feature__body">
          <span class="g-badge g-badge--soft"><i class="fa-solid fa-calendar" aria-hidden="true"></i> {STRINGS.nextMeetup}</span>
          <h2 style="margin:0">{next.data.title}</h2>
          <div class="g-meta-line">
            <span><i class="fa-solid fa-calendar-day" aria-hidden="true"></i> {next.data.date.toLocaleDateString(SITE.locale, { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' })}{next.data.time && ` · ${next.data.time}`}</span>
            <span><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {nextVenue ?? next.data.venue ?? STRINGS.venueTba}</span>
          </div>
          {next.data.description && <p style="margin:0;color:var(--text-muted);max-width:34rem">{next.data.description}</p>}
          <div class="g-row">
            {next.data.rsvp && <a class="g-btn g-btn--primary" href={next.data.rsvp}><i class="fa-solid fa-calendar" aria-hidden="true"></i> {STRINGS.rsvpExternal}</a>}
            <a class="g-btn g-btn--outline" href="/events/">{STRINGS.allEvents}</a>
          </div>
        </div>
      </div>
    </section>
  )}

  {posts.length > 0 && (
    <section class="g-bg-white g-section">
      <div class="g-container">
        <div class="g-row" style="justify-content:space-between;align-items:flex-end">
          <div class="g-section-head">
            <span class="g-eyebrow">{STRINGS.fromTheBlog}</span>
            <h2>{STRINGS.latestFromCommunity}</h2>
          </div>
          <a class="g-btn g-btn--ghost" href="/blog/">{STRINGS.readTheBlog} <i class="fa-solid fa-arrow-right" aria-hidden="true"></i></a>
        </div>
        <div class="g-grid-3" style="margin-top:var(--space-4)">
          {posts.map((p) => <PostCard post={p} />)}
        </div>
      </div>
    </section>
  )}

  {organizers.length > 0 && (
    <section class="g-bg-tertiary g-section">
      <div class="g-container">
        <div class="g-section-head g-section-head--center">
          <span class="g-eyebrow">The team</span>
          <h2>Meet the organizers</h2>
          <p class="g-lead">The volunteers who make every meetup happen.</p>
        </div>
        <div class="g-grid-3" style="margin-top:var(--space-5)">
          {organizers.slice(0, 3).map((o) => <OrganizerCard organizer={o} />)}
        </div>
        <div class="g-row" style="justify-content:center;margin-top:var(--space-4)">
          <a class="g-btn g-btn--outline" href="/organizers/">All organizers</a>
        </div>
      </div>
    </section>
  )}

  {h.testimonials && (
    <section class="g-bg-white g-section">
      <div class="g-container">
        {h.testimonialsHead && (
          <div class="g-section-head g-section-head--center">
            {h.testimonialsHead.eyebrow && <span class="g-eyebrow">{h.testimonialsHead.eyebrow}</span>}
            <h2>{h.testimonialsHead.title}</h2>
            {h.testimonialsHead.lead && <p class="g-lead">{h.testimonialsHead.lead}</p>}
          </div>
        )}
        <div class="g-grid-3" style="margin-top:var(--space-5)">
          {h.testimonials.map((t) => (
            <figure class="g-quote">
              <blockquote>{t.quote}</blockquote>
              <figcaption>
                {t.photo && <img src={t.photo} alt={t.name} />}
                <div><span class="g-quote__name">{t.name}</span>{t.role && <span class="g-quote__role">{t.role}</span>}</div>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  {h.getInvolved && (
    <section class="g-bg-wash g-section">
      <div class="g-container" style="text-align:center;display:flex;flex-direction:column;align-items:center;gap:1rem">
        <span class="g-eyebrow">{h.getInvolved.eyebrow ?? 'Community'}</span>
        <h2 style="margin:0;max-width:40rem">{h.getInvolved.title}</h2>
        {h.getInvolved.lead && <p style="margin:0;color:var(--ink-700);max-width:38rem">{h.getInvolved.lead}</p>}
        <div class="g-row" style="justify-content:center">
          {h.getInvolved.ctas.map((c) => (
            <a class={`g-btn g-btn--${c.variant ?? 'primary'}`} href={c.url}>{c.label}</a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
