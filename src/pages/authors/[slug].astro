---
import { STRINGS } from '../../config';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const posts = (await getCollection('blog'))
  .filter((p) => p.data.authors.includes(entry.id))
  .sort((a, b) => +b.data.date - +a.data.date);
---

<BaseLayout title={entry.data.title} description={entry.data.bio}>
  <PageHero eyebrow={STRINGS.eyebrowAuthor} title={entry.data.title} lead={entry.data.bio} />
  <section class="g-bg-white g-section">
    <div class="g-container">
      <div class="g-narrow" style="margin:0 auto var(--space-5)">
        <AuthorBox entry={entry} />
        <div class="g-prose" style="margin-top:var(--space-4)"><Content /></div>
      </div>
      {posts.length > 0 && (
        <>
          <div class="g-section-head"><span class="g-eyebrow">{STRINGS.posts}</span><h2>{STRINGS.writtenBy.replace('{name}', entry.data.title)}</h2></div>
          <div class="g-grid-3" style="margin-top:var(--space-4)">
            {posts.map((p) => <PostCard post={p} />)}
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>
