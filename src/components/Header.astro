---
import { SITE, NAV, CTA, STRINGS } from '../config';
const path = Astro.url.pathname;
const isActive = (href: string) => href !== '/' && path.startsWith(href.replace(/\/$/, ''));
---

<header class="g-header">
  <nav class="g-container g-nav" aria-label={STRINGS.primaryNav}>
    <a class="g-brand" href="/">
      {SITE.logo && <img src={SITE.logo} alt={SITE.title} />}
      <span class="g-brand__text">
        <span class="g-brand__name">{SITE.brandName ?? SITE.title}</span>
        {SITE.brandSub && <span class="g-brand__sub">{SITE.brandSub}</span>}
      </span>
    </a>

    <button class="g-nav__toggle" aria-label={STRINGS.toggleMenu} aria-expanded="false">
      <i class="fa-solid fa-bars" aria-hidden="true"></i>
    </button>

    <ul class="g-navlinks">
      {NAV.map((l) =>
        l.children?.length ? (
          <li class="has-sub">
            <a
              href={l.href}
              class={isActive(l.href) || l.children.some((c) => isActive(c.href)) ? 'is-active' : ''}
            >
              {l.label}<i class="fa-solid fa-chevron-down g-navlinks__caret" aria-hidden="true"></i>
            </a>
            <ul class="g-navlinks__sub">
              {l.children.map((c) => (
                <li><a href={c.href} class={isActive(c.href) ? 'is-active' : ''}>{c.label}</a></li>
              ))}
            </ul>
          </li>
        ) : (
          <li><a href={l.href} class={isActive(l.href) ? 'is-active' : ''}>{l.label}</a></li>
        )
      )}
    </ul>

    {CTA && (
      <a class="g-btn g-btn--primary g-btn--sm g-nav__cta" href={CTA.url}>
        {CTA.icon && <i class={CTA.icon} aria-hidden="true"></i>}{CTA.label}
      </a>
    )}
  </nav>
</header>
