---
import { STRINGS } from '../config';
/** Checklist: use inside MDX:
 *  <Checklist id="rb-venue" items={[ 'Shortlist venues', 'Confirm access' ]} />
 *  `id` must be unique across the site, it namespaces the saved progress
 *  (localStorage, same key format as the Hugo theme: popular-check:<id>). */
interface Props {
  id: string;
  items: string[];
}
const { id, items } = Astro.props;
---

<div class="g-checklist" data-key={id}>
  <div class="g-checklist__head">
    <span>{STRINGS.checklist}</span>
    <span class="g-checklist__count">0/{items.length} {STRINGS.checklistDone}</span>
  </div>
  <ul>
    {items.map((item) => (
      <li>
        <button class="g-check" type="button" role="checkbox" aria-checked="false">
          <span class="g-check__box"></span>
          <span class="g-check__label">{item}</span>
        </button>
      </li>
    ))}
  </ul>
</div>
