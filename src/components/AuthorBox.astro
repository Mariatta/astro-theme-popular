---
import { STRINGS } from '../config';
/** AuthorBox: bio card for a post author.
 *  Pass either `entry` (an authors-collection entry, linked to its profile)
 *  or `guest` (inline guestAuthors object from a post's front matter). */
import type { CollectionEntry } from 'astro:content';

interface Guest {
  name: string; title?: string; photo?: string; bio?: string; website?: string;
  social?: { label: string; icon: string; url: string }[];
}
interface Props { entry?: CollectionEntry<'authors'>; guest?: Guest }
const { entry, guest } = Astro.props;
const d = entry?.data;
---

<div class="g-persona g-persona--primary">
  {d && (
    <>
      {d.photo && <img class="g-persona__img" src={d.photo} alt={entry.data.title} />}
      <div>
        <div class="g-persona__name"><a href={`/authors/${entry.id}/`} style="color:inherit">{d.title}</a></div>
        {d.role && <div class="g-persona__role">{d.role}</div>}
        {d.bio && <p class="g-persona__bio">{d.bio}</p>}
        <div class="g-persona__socials">
          {d.website && <a href={d.website} aria-label={STRINGS.website} rel="noopener" target="_blank"><i class="fa-solid fa-globe" aria-hidden="true"></i></a>}
          {d.social.map((s) => <a href={s.url} aria-label={s.label} rel="noopener" target="_blank"><i class={s.icon} aria-hidden="true"></i></a>)}
        </div>
      </div>
    </>
  )}
  {guest && (
    <>
      {guest.photo && <img class="g-persona__img" src={guest.photo} alt={guest.name} />}
      <div>
        <div class="g-persona__name">{guest.name} <span class="g-badge g-badge--soft" style="vertical-align:middle">{STRINGS.guest}</span></div>
        {guest.title && <div class="g-persona__role">{guest.title}</div>}
        {guest.bio && <p class="g-persona__bio">{guest.bio}</p>}
        <div class="g-persona__socials">
          {guest.website && <a href={guest.website} aria-label={STRINGS.website} rel="noopener" target="_blank"><i class="fa-solid fa-globe" aria-hidden="true"></i></a>}
          {(guest.social ?? []).map((s) => <a href={s.url} aria-label={s.label} rel="noopener" target="_blank"><i class={s.icon} aria-hidden="true"></i></a>)}
        </div>
      </div>
    </>
  )}
</div>
