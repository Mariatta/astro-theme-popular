---
import { SITE, FOOTER, SOCIAL } from '../config';
const year = new Date().getFullYear();
const credit = (FOOTER as { credit?: { label: string; url: string } }).credit;
---

<footer class="g-footer">
  <div class="g-container g-footer__top">
    <div class="g-footer__brand">
      {SITE.logo && <img src={SITE.logo} alt={SITE.title} />}
      {SITE.landAcknowledgement && <p class="g-footer__ack">{SITE.landAcknowledgement}</p>}
      {SOCIAL.length > 0 && (
        <div style="display:flex;gap:0.5rem;margin-top:0.25rem">
          {SOCIAL.map((s) => (
            <a class="g-social" href={s.url} aria-label={s.label} rel="me noopener" target="_blank">
              <i class={s.icon} aria-hidden="true"></i>
            </a>
          ))}
        </div>
      )}
    </div>

    {FOOTER.columns.map((col) => (
      <div class="g-footer__col">
        <div class="g-footer__col-title">{col.title}</div>
        <ul>
          {col.links.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="g-footer__bottom">
    <div class="g-container">
      <span>© {year} {SITE.title}</span>
      {credit && <span><a href={credit.url} rel="noopener">{credit.label}</a></span>}
      {FOOTER.tagline && <span>{FOOTER.tagline}</span>}
    </div>
  </div>
</footer>
