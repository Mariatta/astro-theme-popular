---
import { STRINGS } from 'popular:config';
import { render } from 'astro:content';
import { safeCollection } from '../../lib/collections';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import EventRow from '../../components/EventRow.astro';

export async function getStaticPaths() {
  const speakers = await safeCollection('speakers');
  return speakers.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const events = (await safeCollection('events'))
  .filter((e) => !e.data.draft && e.data.speakers.includes(entry.id))
  .sort((a, b) => +b.data.date - +a.data.date);
---

<BaseLayout title={entry.data.title} description={entry.data.bio}>
  <PageHero eyebrow={STRINGS.eyebrowSpeaker} title={entry.data.title} lead={entry.data.bio} />
  <section class="g-bg-white g-section">
    <div class="g-container">
      <div class="g-article" style="margin-bottom:var(--space-5)">
        <AuthorBox entry={entry} base="/speakers/" />
        <div class="g-prose" style="margin-top:var(--space-4)"><Content /></div>
      </div>
      {events.length > 0 && (
        <>
          <div class="g-section-head"><span class="g-eyebrow">{STRINGS.eyebrowEvents}</span><h2>{STRINGS.sessionsBy.replace('{name}', entry.data.title)}</h2></div>
          <div class="g-stack" style="margin-top:var(--space-4);gap:var(--space-3)">
            {events.map((e) => <EventRow event={e} />)}
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>
