---
import { STRINGS } from 'popular:config';
import { render } from 'astro:content';
import { safeCollection } from '../../lib/collections';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import AuthorBox from '../../components/AuthorBox.astro';

export async function getStaticPaths() {
  const organizers = await safeCollection('organizers');
  return organizers.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={d.title} description={d.description}>
  <PageHero eyebrow={d.role ?? STRINGS.eyebrowOrganizer} title={d.title} lead={d.description} />
  <section class="g-bg-white g-section">
    <div class="g-container">
      <div class="g-article">
        <AuthorBox entry={entry} base="/organizers/" />
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>
