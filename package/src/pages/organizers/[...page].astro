---
import { safeCollection } from '../../lib/collections';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import OrganizerCard from '../../components/OrganizerCard.astro';
import Pagination from '../../components/Pagination.astro';
import { SECTIONS, PAGINATION } from 'popular:config';

/* One route serves /organizers/ and /organizers/page/N/, matching the Hugo
   theme's paginator URLs. */
export async function getStaticPaths() {
  const organizers = (await safeCollection('organizers')).sort((a, b) => a.data.weight - b.data.weight);
  const size = PAGINATION.pageSize;
  const total = Math.max(1, Math.ceil(organizers.length / size));
  return Array.from({ length: total }, (_, i) => ({
    params: { page: i === 0 ? undefined : `page/${i + 1}` },
    props: { current: i + 1, total, organizers: organizers.slice(i * size, (i + 1) * size) },
  }));
}

const { current, total, organizers } = Astro.props;
---

<BaseLayout title="Organizers">
  <PageHero
    eyebrow={SECTIONS.organizers.eyebrow}
    title={SECTIONS.organizers.title}
    lead={SECTIONS.organizers.lead}
  />
  <section class="g-bg-white g-section">
    <div class="g-container">
      <div class="g-grid-3">
        {organizers.map((o) => <OrganizerCard organizer={o} />)}
      </div>
      <Pagination current={current} total={total} base="/organizers/" />
    </div>
  </section>
</BaseLayout>