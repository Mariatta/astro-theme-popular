---
/** One FAQ item: native <details> (zero JS). `q` is the question; the default
 *  slot is the markdown answer. `open` renders it expanded. */
interface Props { q: string; open?: boolean }
const { q, open = false } = Astro.props;
---
<details class="g-faq__item" open={open}>
  <summary class="g-faq__q">{q}</summary>
  <div class="g-faq__a g-prose"><slot /></div>
</details>
