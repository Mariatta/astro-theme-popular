---
/* Pager for paginated lists. Mirrors the Hugo theme's
   layouts/partials/pagination.html (see PARITY.md).
   `base` is the section's root URL ("/blog/"); page 1 links to the base
   itself, page N to `${base}page/N/`, matching Hugo's paginator URLs.
   Renders nothing when everything fits on one page. */
import { STRINGS } from 'popular:config';

interface Props {
  current: number;
  total: number;
  base: string;
}
const { current, total, base } = Astro.props;
const url = (n: number) => (n === 1 ? base : `${base}page/${n}/`);
const pages = Array.from({ length: total }, (_, i) => i + 1);
---

{total > 1 && (
  <nav class="g-pager" aria-label={STRINGS.paginationLabel}>
    {current > 1 && (
      <a class="g-pager__nav" href={url(current - 1)} rel="prev"><i class="fa-solid fa-chevron-left" aria-hidden="true"></i>{STRINGS.paginationPrev}</a>
    )}
    {pages.map((n) =>
      n === current ? (
        <span class="g-pager__num is-active" aria-current="page">{n}</span>
      ) : (
        <a class="g-pager__num" href={url(n)}>{n}</a>
      )
    )}
    {current < total && (
      <a class="g-pager__nav" href={url(current + 1)} rel="next">{STRINGS.paginationNext}<i class="fa-solid fa-chevron-right" aria-hidden="true"></i></a>
    )}
  </nav>
)}