---
/** DemoBar: fixed demo switcher, rendered ONLY when the config exports a
 *  non-null DEMO_BAR (the theme's own demo builds). Adopters: set
 *  `export const DEMO_BAR = null;` (or remove demo content) and it disappears.
 *  Links are computed client-side by swapping the /<slug>/ path segment. */
import * as cfg from 'popular:config';
const bar = import.meta.env.DEV ? null : ((cfg as Record<string, any>).DEMO_BAR ?? null);
---

{bar && (
  <>
    <style>
      .g-demobar { position: fixed; bottom: 14px; left: 50%; transform: translateX(-50%); z-index: 90;
        display: flex; align-items: center; gap: 2px; padding: 5px;
        background: color-mix(in srgb, var(--ink-900) 92%, transparent); color: var(--ink-200);
        border-radius: var(--radius-pill); box-shadow: var(--shadow-lg); font-size: var(--text-xs);
        font-family: var(--font-sans); backdrop-filter: blur(8px); }
      .g-demobar__label { padding: 0 8px 0 12px; color: var(--ink-400); font-weight: var(--weight-semibold);
        letter-spacing: var(--tracking-wide); text-transform: uppercase; font-size: 0.65rem; }
      .g-demobar a { display: inline-flex; align-items: center; gap: 6px; padding: 7px 12px;
        border-radius: var(--radius-pill); color: var(--ink-300); text-decoration: none; white-space: nowrap; }
      .g-demobar a:hover { color: #fff; background: rgba(255,255,255,0.08); }
      .g-demobar a.is-current { background: var(--color-primary); color: #fff; }
      @media (max-width: 640px) { .g-demobar__label { display: none; } }
    </style>
    <nav class="g-demobar" aria-label="Theme demos">
      <a href="#" data-demo-home><i class="fa-solid fa-star" aria-hidden="true"></i>Popular</a>
      <span class="g-demobar__label">Demo</span>
      {bar.links.map((l: any) => (
        <a href="#" data-demo={l.slug} class={l.slug === bar.current ? 'is-current' : ''}>
          <i class={l.icon} aria-hidden="true"></i>{l.label}
        </a>
      ))}
      {bar.repo && <a href={bar.repo} rel="noopener" target="_blank"><i class="fa-brands fa-github" aria-hidden="true"></i>Source</a>}
    </nav>
    <script is:inline define:vars={{ slugs: bar.links.map((l: any) => l.slug) }}>
      (function () {
        var path = window.location.pathname;
        var re = new RegExp('/(' + slugs.join('|') + ')/');
        var home = document.querySelector('.g-demobar a[data-demo-home]');
        if (home) { var m = path.search(re); home.href = m >= 0 ? path.slice(0, m + 1) : '/'; }
        document.querySelectorAll('.g-demobar a[data-demo]').forEach(function (a) {
          var slug = a.getAttribute('data-demo');
          if (re.test(path)) a.href = path.replace(re, '/' + slug + '/').replace(/\/[^/]*$/, '/');
          else a.href = '/' + slug + '/';
        });
      })();
    </script>
  </>
)}
