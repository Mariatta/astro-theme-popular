---
/** Callout: use inside MDX: <Callout tone="tip" title="Two-deep rule">…</Callout>
 *  tone: info | tip | warn (mirrors the Hugo `callout` shortcode). */
interface Props {
  tone?: 'info' | 'tip' | 'warn';
  title?: string;
}
const { tone = 'info', title } = Astro.props;
const icons = {
  info: 'fa-solid fa-circle-info',
  tip: 'fa-solid fa-lightbulb',
  warn: 'fa-solid fa-triangle-exclamation',
};
---

<div class={`g-callout${tone !== 'info' ? ` g-callout--${tone}` : ''}`}>
  <i class={icons[tone]} aria-hidden="true"></i>
  <div class="g-callout__body">
    {title && <div class="g-callout__title">{title}</div>}
    <slot />
  </div>
</div>
