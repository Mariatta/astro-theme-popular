---
/** Popular: base layout: head, brand token overrides, header, footer, shared JS. */
import '../styles/tokens/fonts.css';
import '../styles/tokens/colors.css';
import '../styles/tokens/typography.css';
import '../styles/tokens/spacing.css';
import '../styles/tokens/elevation.css';
import '../styles/base.css';
import '../styles/components.css';
import Header from 'popular:component/Header';
import Footer from 'popular:component/Footer';
import DemoBar from '../components/DemoBar.astro';
import { SITE, BRAND, STRINGS } from 'popular:config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Set on blog posts: emits og:type=article plus article meta. */
  article?: { published?: Date; modified?: Date; authors?: string[]; tags?: string[] };
  imageAlt?: string;
  noindex?: boolean;
}
const { title, description, image, article, imageAlt, noindex } = Astro.props;
const ogLocale = SITE.locale.replace('-', '_');
const pageTitle = title ? `${title} · ${SITE.title}` : `${SITE.title}, ${SITE.tagline}`;
const desc = description ?? SITE.description;
const ogImage = image ?? SITE.ogImage;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

/* Brand overrides: mirrors the Hugo theme's brand-vars.html partial. */
const vars: string[] = [];
const b = BRAND;
if (b.primary) {
  vars.push(`--color-primary:${b.primary}`, `--gold-500:${b.primary}`);
  vars.push(`--gold-50:color-mix(in srgb, ${b.primary} 7%, #fff)`);
  vars.push(`--gold-100:color-mix(in srgb, ${b.primary} 20%, #fff)`);
  vars.push(`--gold-300:color-mix(in srgb, ${b.primary} 55%, #fff)`);
}
if (b.primaryHover) vars.push(`--color-primary-hover:${b.primaryHover}`);
if (b.primaryActive) vars.push(`--color-primary-active:${b.primaryActive}`, `--gold-700:${b.primaryActive}`, `--text-link:${b.primaryActive}`);
if (b.link) vars.push(`--text-link:${b.link}`);
if (b.linkHover) vars.push(`--text-link-hover:${b.linkHover}`);
if (b.secondary) vars.push(`--color-secondary:${b.secondary}`);
if (b.accent) vars.push(`--color-accent:${b.accent}`, `--indigo-500:${b.accent}`);
if (b.accentHover) vars.push(`--color-accent-hover:${b.accentHover}`);
if (b.ink) vars.push(`--ink-800:${b.ink}`, `--text-strong:${b.ink}`);
if (b.surfaceWash) vars.push(`--surface-wash:${b.surfaceWash}`);
if (b.surfaceWashSoft) vars.push(`--surface-wash-soft:${b.surfaceWashSoft}`);
if (b.surfaceInk) vars.push(`--surface-ink:${b.surfaceInk}`);
/* Dark-palette keys: page/card surfaces, body text, borders, and the text
   color on filled buttons. Setting these lets a site run on a dark background. */
if (b.surfacePage) vars.push(`--surface-page:${b.surfacePage}`);
if (b.surfaceCard) vars.push(`--surface-card:${b.surfaceCard}`);
if (b.surfaceTertiary) vars.push(`--surface-tertiary:${b.surfaceTertiary}`);
if (b.textBody) vars.push(`--text-body:${b.textBody}`, `--ink-700:${b.textBody}`);
if (b.textMuted) vars.push(`--text-muted:${b.textMuted}`, `--ink-500:${b.textMuted}`);
if (b.textOnBrand) vars.push(`--text-on-brand:${b.textOnBrand}`);
if (b.borderSubtle) vars.push(`--border-subtle:${b.borderSubtle}`, `--border-default:${b.borderSubtle}`);
if (b.fontSans) vars.push(`--font-sans:${b.fontSans}`);
if (b.fontDisplay) vars.push(`--font-display:${b.fontDisplay}`);
if (b.radiusCard) vars.push(`--radius-xl:${b.radiusCard}`);
if (b.containerMax) vars.push(`--container-max:${b.containerMax}`);
/* html:root outranks the token files' :root so the override wins regardless of
   where Astro injects the bundled stylesheet in <head>. */
const brandCss = `html:root{${vars.join(';')}}`;
---

<!DOCTYPE html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title ?? SITE.title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    {article?.published && <meta property="article:published_time" content={article.published.toISOString()} />}
    {article?.modified && <meta property="article:modified_time" content={article.modified.toISOString()} />}
    {article?.authors?.map((a) => <meta property="article:author" content={a} />)}
    {article?.tags?.map((t) => <meta property="article:tag" content={t} />)}
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url)} />}
    {ogImage && <meta property="og:image:alt" content={imageAlt ?? title ?? SITE.title} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <link rel="icon" href={SITE.favicon ?? SITE.logo} />
    <link rel="alternate" type="application/rss+xml" title={(SITE as Record<string, any>).rssTitle ?? SITE.title} href={new URL("rss.xml", Astro.site ?? Astro.url)} />
    {SITE.fontAwesome.includes("font-awesome/6.5.2/css/all.min.css") && <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />}
    <link rel="stylesheet" href={SITE.fontAwesome} referrerpolicy="no-referrer"
      integrity={SITE.fontAwesome.includes("font-awesome/6.5.2/css/all.min.css") ? "sha384-PPIZEGYM1v8zp5Py7UjFb79S58UeqCL9pYVnVPURKEqvioPROaVAJKKLzvH2rDnI" : undefined}
      crossorigin={SITE.fontAwesome.includes("font-awesome/6.5.2/css/all.min.css") ? "anonymous" : undefined} />
    {(SITE as Record<string, any>).customCSS?.map((href: string) => <link rel="stylesheet" href={href} />)}
    {noindex && <meta name="robots" content="noindex,follow" />}
    <style is:inline id="popular-brand" set:html={brandCss}></style>
    <slot name="head" />
  </head>
  <body data-copy-label={STRINGS.copyCode} data-checklist-done={STRINGS.checklistDone}>
    <a class="g-skip" href="#main">{STRINGS.skipToContent}</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <DemoBar />
  </body>
</html>
