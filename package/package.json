{
  "name": "astro-theme-popular",
  "version": "0.4.0",
  "description": "Popular: a warm, community-first Astro theme for meetups, clubs and fan communities. Ships as an Astro integration.",
  "type": "module",
  "license": "MIT",
  "author": "Mariatta",
  "homepage": "https://mariatta.ca/hugo-theme-popular/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mariatta/astro-theme-popular.git"
  },
  "keywords": [
    "astro-integration",
    "astro-theme",
    "community",
    "meetup",
    "events"
  ],
  "exports": {
    ".": "./index.mjs",
    "./schemas": "./schemas.ts",
    "./pages/*": "./src/pages/*",
    "./components/*": "./src/components/*",
    "./layouts/*": "./src/layouts/*",
    "./styles/*": "./src/styles/*",
    "./scripts/*": "./scripts/*"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.0"
  },
  "peerDependencies": {
    "astro": "^7.0.0"
  },
  "files": [
    "index.mjs",
    "schemas.ts",
    "src",
    "scripts",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
