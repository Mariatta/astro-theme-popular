{
  // Self-contained on purpose: no extends chain to resolve (see the root
  // tsconfig's comment). Matches astro/tsconfigs/base essentials.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "jsx": "preserve"
  },
  "include": [".astro/types.d.ts", "src/**/*", "popular.config.ts"]
}
