{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "photo": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "social": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "label",
          "icon",
          "url"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}