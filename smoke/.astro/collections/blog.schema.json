{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "author": {
      "type": "string"
    },
    "authors": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "guestAuthors": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "photo": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "website": {
            "type": "string"
          },
          "social": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "icon": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              },
              "required": [
                "label",
                "icon",
                "url"
              ]
            }
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "description": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "speaker": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "photo": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}